rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Libera leitura para Banners (Vitrine)
    match /banners_fixos/{document=**} { allow read: if true; allow write: if request.auth != null; }
    
    // 2. Libera leitura para Produtos
    match /produtos/{document=**} { allow read: if true; allow write: if request.auth != null; }
    
    // 3. Libera leitura para Cupons
    match /cupons/{document=**} { allow read: if true; allow write: if request.auth != null; }
    
    // 4. A CORREÇÃO: Libera leitura para Cidades/Frete (ISSO FALTAVA)
    match /locais_entrega/{document=**} { allow read: if true; allow write: if request.auth != null; }
    
    // 5. Pedidos: Qualquer um cria, mas só admin lê/edita
    match /pedidos/{pedidoId} { allow create: if true; allow read, update, delete: if request.auth != null; }
    
    // 6. Regra geral: Bloqueia o resto para quem não é admin
    match /{document=**} { allow read, write: if request.auth != null; }
  }
}