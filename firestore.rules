rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /banners_fixos/{document=**} { allow read: if true; allow write: if request.auth != null; }
    match /produtos/{document=**} { allow read: if true; allow write: if request.auth != null; }
    match /cupons/{document=**} { allow read: if true; allow write: if request.auth != null; }
    match /pedidos/{pedidoId} { allow create: if true; allow read, update, delete: if request.auth != null; }
    match /{document=**} { allow read, write: if request.auth != null; }
  }
}